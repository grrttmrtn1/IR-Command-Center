# Database
POSTGRES_PASSWORD=change_me_strong_password

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change_me_64_char_hex_string_for_jwt_signing
# Encryption key for SSO configs and AI API keys — generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_32_char_hex_string_for_aes256

# Optional: SMTP for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ircc@yourcompany.com

# Optional: S3-compatible storage (leave blank to use local Docker volume)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ircc-uploads
